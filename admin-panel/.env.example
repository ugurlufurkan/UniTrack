# UniTrack mobil backend'iyle AYNI veritabanı (aynı Postgres instance/DB).
DATABASE_URL=postgresql://user:password@localhost:5432/unitrack

# `openssl rand -base64 32` ile üretin.
BETTER_AUTH_SECRET=

# Admin panelin kendi adresi (prod'da gerçek domain).
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
