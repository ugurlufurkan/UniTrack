# UniTrack backend — ortam değişkenleri şablonu.
# Bu dosyayı kopyalayıp `.env` yap, gerçek değerleri doldur.
# `.env` asla commit edilmez (bkz. .gitignore).

# Postgres bağlantı adresi. Prod'da hosting sağlayıcının (Render/Railway/Neon/Supabase)
# verdiği bağlantı dizesini kullan — localhost DEĞİL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unitrack

PORT=5000

NODE_ENV=development

# Access/refresh token imzalama secret'ları. Üretmek için:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# İkisi de birbirinden FARKLI, en az 64 byte rastgele değer olmalı.
JWT_SECRET=
JWT_REFRESH_SECRET=

# Google Cloud Console > OAuth 2.0 Client IDs altındaki "Web application" client ID'si.
GOOGLE_CLIENT_ID=

# Prod'da mobil uygulama origin göndermediği için CORS'u etkilemez ama
# tarayıcıdan (ör. admin panel) erişim olacaksa virgülle ayrılmış allow-list.
ALLOWED_ORIGINS=https://unitrack.app

FRONTEND_URL=http://localhost:3000

# Opsiyonel — e-posta gönderimi kullanılıyorsa doldur.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
