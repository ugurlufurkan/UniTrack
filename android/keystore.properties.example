# Bu dosyayı `keystore.properties` olarak kopyala ve gerçek değerlerle doldur.
# `keystore.properties` (gerçek değerlerle) ASLA commit edilmemeli — android/.gitignore
# bunu zaten hariç tutuyor.
#
# Keystore oluşturmak için (bir kere, sakla — kaybedersen Play'de aynı
# uygulamayı GÜNCELLEYEMEZSİN, sadece Play App Signing kullanıyorsan upload
# key'i sıfırlatabilirsin):
#
#   keytool -genkeypair -v -storetype PKCS12 \
#     -keystore unitrack-release.keystore \
#     -alias unitrack -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile, bu dosyaya göre (android/ klasörüne göre) göreli bir yol olmalı.
storeFile=unitrack-release.keystore
storePassword=
keyAlias=unitrack
keyPassword=
